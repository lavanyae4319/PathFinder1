                    </div>
                </section>
                {% endblock %}

                {% block extra_js %}
                <script src="{{ url_for('static', filename='js/generator.js') }}"></script>
                <script>
                    // Debug script to verify buttons exist
                    $(document).ready(function () {
                        console.log('Debug: jQuery version', $.fn.jquery);
                        console.log('Debug: Preview button exists?', $('#previewBtn').length);
                        console.log('Debug: Generate button exists?', $('#generateBtn').length);

                        // Backup handlers in case the main ones don't work
                        setTimeout(function () {
                            $('#previewBtn').off('click').on('click', function (e) {
                                e.preventDefault();
                                e.stopPropagation();
                                console.log('BACKUP: Preview clicked');
                                alert('Preview button clicked! Check console for data.');
                            });

                            $('#generateBtn').off('click').on('click', function (e) {
                                e.preventDefault();
                                e.stopPropagation();
                                console.log('BACKUP: Generate clicked');
                                alert('Generate button clicked! Check console for data.');
                            });
                        }, 1000);
                    });
                </script>
                {% endblock %}